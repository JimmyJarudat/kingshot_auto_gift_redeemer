  "name": "Kingshot - Flow 2 Redeem API Loop + Delays",
  "nodes": [
    {
      "parameters": {},
      "id": "3d4657c9-abd4-44a0-9c1a-6c7939b4eec7",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        304,
        2800
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH candidate AS (\n    SELECT\n        r.id AS redemption_id,\n        gc.code AS gift_code,\n        ga.player_id,\n        ga.nickname,\n        ga.server_id\n    FROM gift_code_redemptions r\n    JOIN gift_codes gc ON gc.id = r.gift_code_id\n    JOIN game_accounts ga ON ga.id = r.game_account_id\n    WHERE r.status = 'pending'\n      AND gc.status = 'active'\n      AND ga.is_active = TRUE\n      AND (gc.expires_at IS NULL OR gc.expires_at > NOW())\n    ORDER BY r.queued_at ASC\n    FOR UPDATE OF r SKIP LOCKED\n    LIMIT 1\n),\nclaimed AS (\n    UPDATE gift_code_redemptions r\n    SET\n        status = 'processing',\n        attempt_count = attempt_count + 1,\n        updated_at = NOW()\n    FROM candidate c\n    WHERE r.id = c.redemption_id\n    RETURNING r.id\n)\nSELECT\n    c.redemption_id,\n    c.gift_code,\n    c.player_id,\n    c.nickname,\n    c.server_id\nFROM candidate c\nJOIN claimed cl ON cl.id = c.redemption_id;",
        "options": {}
      },
      "id": "fd18708e-5946-4910-a810-923b67d30488",
      "name": "Claim One Pending Job",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        608,
        2720
      ],
      "credentials": {
        "postgres": {
          "id": "d4tyOp9jNnFC1MME",
          "name": "Postgres account 2"
        }
      }
