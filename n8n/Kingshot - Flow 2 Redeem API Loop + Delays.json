    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst SECRET_KEY = 'mN4!pQs6JrYwV9';\nconst item = $input.first().json;\n\nconst playerParams = {\n  fid: String(item.player_id),\n  time: String(Date.now()),\n};\n\nconst raw = Object.keys(playerParams)\n  .sort()\n  .map((key) => `${key}=${playerParams[key]}`)\n  .join('&');\n\nconst sign = crypto\n  .createHash('md5')\n  .update(raw + SECRET_KEY, 'utf8')\n  .digest('hex');\n\nreturn [{\n  json: {\n    ...item,\n    player_form: {\n      sign,\n      ...playerParams,\n    },\n  },\n}];"
      },
