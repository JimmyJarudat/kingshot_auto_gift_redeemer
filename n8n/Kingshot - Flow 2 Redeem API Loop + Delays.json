      "id": "53d57076-4926-4e39-b3e1-352a5cd6eb94",
      "name": "Redeem Code",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2400,
        2592
      ]
    },
    {
      "parameters": {
        "jsCode": "const job = $('Claim One Pending Job').first().json;\nconst http = $input.first().json;\nconst payload = http.body ?? http.data ?? http;\n\nconst code = Number(payload?.code ?? -1);\nconst errCode = Number(payload?.err_code ?? payload?.data?.err_code ?? -1);\nconst message = String(payload?.msg ?? 'Unknown response');\n\nlet status = 'failed';\n\nif (code === 0 && errCode === 20000) {\n  status = 'success';\n} else if ([40001, 40003, 40007].includes(errCode)) {\n  status = 'already_redeemed';\n} else if (errCode === 40002) {\n  status = 'expired';\n} else if (errCode === 40006) {\n  status = 'failed';\n} else if ([40102, 40103, 40104].includes(errCode)) {\n  status = 'failed';\n}\n\nreturn [{\n  json: {\n    redemption_id: job.redemption_id,\n    result_status: status,\n    response_message: message,\n    response_data: payload,\n    http_status: http.statusCode ?? null,\n    err_code: errCode,\n  },\n}];"
      },
