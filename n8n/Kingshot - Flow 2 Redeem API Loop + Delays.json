      "id": "629cf7a8-4bff-4a28-9ca7-9c328bce2a8a",
      "name": "Verify Player",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1328,
        2720
      ]
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst SECRET_KEY = 'mN4!pQs6JrYwV9';\nconst job = $('Claim One Pending Job').first().json;\nconst response = $input.first().json;\nconst payload = response.body ?? response.data ?? response;\n\nif (Number(payload?.code) !== 0) {\n  return [{\n    json: {\n      ...job,\n      skip_redeem: true,\n      result_status: 'failed',\n      response_message: payload?.msg ?? 'Player verification failed',\n      response_data: payload,\n      http_status: response.statusCode ?? null,\n    },\n  }];\n}\n\nconst redeemParams = {\n  fid: String(job.player_id),\n  cdk: String(job.gift_code),\n  captcha_code: '',\n  time: String(Math.floor(Date.now() / 1000)),\n};\n\nconst raw = Object.keys(redeemParams)\n  .sort()\n  .map((key) => `${key}=${redeemParams[key]}`)\n  .join('&');\n\nconst sign = crypto\n  .createHash('md5')\n  .update(raw + SECRET_KEY, 'utf8')\n  .digest('hex');\n\nreturn [{\n  json: {\n    ...job,\n    skip_redeem: false,\n    player_response: payload,\n    redeem_form: {\n      sign,\n      ...redeemParams,\n    },\n  },\n}];"
      },
